    "import pandas as pd \n",
    "\n",
    "df = pd.read_csv('cardDB.csv', encoding='GBK')\n",
    "# 筛选职业为 Ironclad 的行\n",
    "ironclad_df = df[df['职业'] == 'Ironclad']\n",
    "\n",
    "# 保存为新 CSV\n",
    "ironclad_df.to_csv('ironclad_card.csv', encoding='GBK')\n",
    "\n",
    "print(f\"✅ 完成！共筛选出 {len(ironclad_df)} 张铁甲战士卡牌\")\n",
    "print(f\"📁 已保存到：ironclad_card.csv\")"
   ]
